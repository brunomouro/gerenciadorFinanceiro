# ============================================
# BANCO DE DADOS
# ============================================
# Em dev local, geralmente você não precisa preencher isso aqui —
# o application-dev.yml já tem valores fixos para Postgres local.
# Essas variáveis passam a ser obrigatórias a partir do profile "prod"
# (e também serão usadas no Dockerfile/docker-compose mais adiante).
DB_URL=jdbc:postgresql://localhost:5432/gerenciadorFinanceiro
DB_USERNAME=postgres
DB_PASSWORD=

# ============================================
# SEGURANÇA - JWT
# ============================================
# Gere um valor forte com: openssl rand -base64 32
# NUNCA reutilize o mesmo valor entre dev e produção
JWT_SECRET=

# ============================================
# E-MAIL (SMTP)
# ============================================
# Para Gmail, EMAIL_PASSWORD precisa ser uma "senha de app",
# não a senha normal da sua conta Google.
# Gerar em: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=
EMAIL_PASSWORD=

# ============================================
# CORS / ORIGENS PERMITIDAS
# ============================================
# Usado apenas no profile "prod" — em dev já está fixo no application-dev.yml
ALLOWED_ORIGINS=

# ============================================
# UPLOAD DE ARQUIVOS
# ============================================
# Usado apenas no profile "prod" — em dev já está fixo no application-dev.yml
UPLOAD_DIR=